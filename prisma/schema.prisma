generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  OFFICER
  ADMIN
}

enum ReportCategory {
  WASTE
  INFRA
  DISTURB
  LAND
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CITIZEN)
  city      String   @default("Jakarta")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  reports       Report[]
  reportJoins   ReportJoin[]
  votes         Vote[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@map("refresh_tokens")
}

model Report {
  id          String         @id @default(cuid())
  title       String
  description String
  category    ReportCategory
  status      ReportStatus   @default(PENDING)

  voteCount Int    @default(0)
  votes     Vote[]

  lat      Float
  lng      Float
  province String
  city     String
  district String
  village  String
  address  String?
  imageUrl String?

  ai_label         String?
  confidence_score Float?
  ai_overridden    Boolean   @default(false)
  ai_override_by   String?
  ai_override_at   DateTime?

  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joins  ReportJoin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lat, lng])
  @@index([category])
  @@index([status])
  @@index([userId])
  @@index([ai_label])
  @@index([voteCount])
  @@map("reports")
}

model ReportJoin {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([reportId, userId])
  @@index([reportId])
  @@index([userId])
  @@map("report_joins")
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
  @@index([reportId])
  @@index([userId])
  @@map("votes")
}