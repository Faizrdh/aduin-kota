generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  OFFICER
  ADMIN
}

enum ReportCategory {
  WASTE
  INFRA
  DISTURB
  LAND
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  IN_PROGRESS
  DISPATCHED
  RESOLVED
  REJECTED
}

enum Priority {
  NORMAL
  HIGH
  EMERGENCY
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CITIZEN)
  city      String   @default("Jakarta")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens   RefreshToken[]
  reports         Report[]
  reportJoins     ReportJoin[]
  votes           Vote[]
  comments        Comment[]
  commentVotes    CommentVote[]
  statusHistories StatusHistory[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  @@index([userId])
  @@map("refresh_tokens")
}

model Report {
  id          String         @id @default(cuid())
  title       String
  description String
  category    ReportCategory
  status      ReportStatus   @default(PENDING)
  priority    Priority       @default(NORMAL)

  voteCount    Int @default(0)
  commentCount Int @default(0)

  votes    Vote[]
  comments Comment[]

  lat           Float
  lng           Float
  province      String
  city          String
  district      String
  village       String
  address       String?
  imageUrl      String?
  reporterEmail String?   

  ai_label         String?
  confidence_score Float?
  ai_overridden    Boolean   @default(false)
  ai_override_by   String?
  ai_override_at   DateTime?

  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joins  ReportJoin[]

  statusHistories StatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lat, lng])
  @@index([category])
  @@index([status])
  @@index([priority])
  @@index([userId])
  @@index([ai_label])
  @@index([voteCount])
  @@index([commentCount])
  @@map("reports")
}

model StatusHistory {
  id         String        @id @default(cuid())
  reportId   String
  report     Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fromStatus ReportStatus?
  toStatus   ReportStatus
  note       String?
  adminId    String?
  admin      User?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt  DateTime      @default(now())

  @@index([reportId])
  @@index([adminId])
  @@index([createdAt])
  @@map("status_histories")
}

model ReportJoin {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([reportId, userId])
  @@index([reportId])
  @@index([userId])
  @@map("report_joins")
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, reportId])
  @@index([reportId])
  @@index([userId])
  @@map("votes")
}

model Comment {
  id          String    @id @default(cuid())
  content     String
  isEdited    Boolean   @default(false)
  deletedAt   DateTime?
  upvoteCount Int       @default(0)

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("CommentReplies")

  votes CommentVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([userId])
  @@index([parentId])
  @@index([reportId, createdAt])
  @@index([upvoteCount])
  @@map("comments")
}

model CommentVote {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
  @@map("comment_votes")
}